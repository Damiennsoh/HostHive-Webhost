# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=HostHive
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
BASE_DOMAIN=hosthive.app

# ============================================================
# Supabase (required for auth + database)
# https://supabase.com/dashboard/project/_/settings/api
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================================
# Coolify (deployment engine)
# Coolify UI → Settings → API Tokens
# ============================================================
COOLIFY_API_URL=http://localhost:8000
COOLIFY_API_TOKEN=your_coolify_api_token
COOLIFY_SECRET_KEY=your_secret_key_here

# ============================================================
# GitHub (OAuth + webhooks)
# GitHub → Developer Settings → GitHub Apps / OAuth Apps
# ============================================================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY=your_github_app_private_key
GITHUB_WEBHOOK_SECRET=your_random_32_char_webhook_secret

# ============================================================
# Email (Resend)
# https://resend.com/api-keys
# ============================================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@hosthive.app

# ============================================================
# Cloudflare Tunnel (optional — public demo URL without VPS)
# docker run cloudflare/cloudflared:latest tunnel login
# ============================================================
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token

# ============================================================
# Local dev stack (optional — if not using Supabase hosted DB)
# ============================================================
DATABASE_URL=postgresql://hosthive:secure_password@localhost:5432/hosthive
POSTGRES_DB=hosthive
POSTGRES_USER=hosthive
POSTGRES_PASSWORD=secure_password
REDIS_URL=redis://localhost:6379

# SSL/TLS
LETS_ENCRYPT_EMAIL=your_email@hosthive.app

# Real Supabase auth (set true only for offline UI demos without Supabase)
NEXT_PUBLIC_MOCK_AUTH=false

# Coolify database provisioning (from Coolify → Servers → copy UUID)
COOLIFY_SERVER_UUID=
COOLIFY_DESTINATION_UUID=
COOLIFY_PROJECT_UUID=
NEXT_PUBLIC_ENABLE_DOCKER_BUILDS=true
NEXT_PUBLIC_ENABLE_CUSTOM_DOMAINS=true
