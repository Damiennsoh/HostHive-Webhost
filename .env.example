# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=HostHive
NEXT_PUBLIC_API_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://hosthive:secure_password@localhost:5432/hosthive
POSTGRES_DB=hosthive
POSTGRES_USER=hosthive
POSTGRES_PASSWORD=secure_password

# Redis
REDIS_URL=redis://localhost:6379

# Coolify Integration
COOLIFY_API_URL=http://localhost:8000
COOLIFY_API_TOKEN=your_coolify_token_here
COOLIFY_SECRET_KEY=your_secret_key_here

# Email/Notifications (Resend)
RESEND_API_KEY=your_resend_api_key_here
NEXT_PUBLIC_FROM_EMAIL=noreply@hosthive.app

# GitHub Integration
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_PRIVATE_KEY=your_github_app_private_key

# SSL/TLS
LETS_ENCRYPT_EMAIL=your_email@hosthive.app

# JWT Secrets
JWT_SECRET=your_jwt_secret_key_min_32_chars
JWT_EXPIRY=7d

# Supabase (Optional - for future integration)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# API Keys
NEXT_PUBLIC_API_VERSION=v1

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Feature Flags
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=true
NEXT_PUBLIC_ENABLE_DOCKER_BUILDS=true
NEXT_PUBLIC_ENABLE_CUSTOM_DOMAINS=true
